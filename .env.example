# Database configuration required by Prisma
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://admin:securepassword123@db:5432/lavyer_db?schema=public"

# PostgreSQL credentials for docker-compose initialization
POSTGRES_USER="admin"
POSTGRES_PASSWORD="securepassword123"
POSTGRES_DB="lavyer_db"

# Authentication Secret
# MUST BE CHANGED IN PRODUCTION! Run `openssl rand -base64 32` to generate one.
JWT_SECRET="super-secret-key-production-change-me"

# Next.js specific
NEXT_TELEMETRY_DISABLED=1

